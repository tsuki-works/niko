# Copy to .env and fill in values fetched via the /shared-creds skill.
# The .env file is gitignored — never commit real credentials.

# Anthropic — Claude Haiku 4.5
ANTHROPIC_API_KEY=

# Deepgram — streaming STT (Nova-2) and TTS (Aura)
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# Twilio — Voice webhook + trial number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public HTTPS base URL of this service. Required for Twilio call
# recording: handed to Twilio when starting a recording, then
# reconstructed in /recording-status to validate Twilio's signature.
# Local: your ngrok URL, e.g. https://abc123.ngrok.app
# Cloud Run: the service URL, e.g. https://niko-xxxxx.a.run.app
PUBLIC_BASE_URL=

# Square — POS sandbox (Phase 2.3)
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
